@page "/"
@inject HttpClient Http
@inject NavigationManager Nav
@using System.Text.Json

<h3>Dynamic Question</h3>

@if (questions is not null)
{
    <p>Loaded @questions.Count questions.</p>
}
else
{
    <p>Loading...</p>
}

@code {
    private List<QuestionDefinition>? questions;

    protected override async Task OnInitializedAsync()
    {
        questions = await LoadQuestionsAsync("multiple-sample-questions.json");
    }

    private async Task<List<QuestionDefinition>?> LoadQuestionsAsync(string path)
    {
        var json = await Http.GetStringAsync($"{Nav.BaseUri}{path}");

        return JsonSerializer.Deserialize<List<QuestionDefinition>>(json, 
            new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
    }
}

