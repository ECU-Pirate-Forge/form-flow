@page "/"
@inject IQuestionService QuestionService
@inject NavigationManager Nav
@using System.Text.Json
@using FormFlow.Blazor.Components.QuestionTypes
@using FormFlow.Blazor.Services

<h3>Dynamic Question</h3>

@if (questions is not null)
{
    <p>Loaded @questions.Count questions.</p>

    <MudStack Spacing="2">
        @foreach (var question in questions)
        {
            <QuestionRenderer @key="question.Id" Question="question" />
        }
    </MudStack>
}
else
{
    <p>Loading...</p>
}

@code {
    private List<QuestionDefinition>? questions = new();


    protected override async Task OnInitializedAsync()
    {
        @* questions = await LoadQuestionsAsync("multiple-sample-questions.json"); *@
        questions = await QuestionService.GetAllQuestionsAsync();
    }

    @* private async Task<List<QuestionDefinition>?> LoadQuestionsAsync(string path)
    {
        var json = await Http.GetStringAsync($"{Nav.BaseUri}{path}");

        return JsonSerializer.Deserialize<List<QuestionDefinition>>(json, 
            new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
    } *@
}

