@page "/admin/questions/create"
@using FormFlow.Blazor.Services
@inject QuestionService QuestionService

<MudPaper Class="pa-6" MaxWidth="600px">
    <MudText Typo="Typo.h5" Class="mb-4">Create Question</MudText>

    <MudForm @ref="_form" Model="@newQuestion" @bind-IsValid="_isValid">
        <MudTextField T="string"
                      Label="Label"
                      @bind-Value="newQuestion.Label"
                      Required="true"
                      RequiredError="Label is required."
                      Immediate="true"
                      Class="mb-3" />

        <MudTextField T="string"
                      Label="Key"
                      @bind-Value="newQuestion.Key"
                      Required="true"
                      RequiredError="Key is required."
                      Immediate="true"
                      Class="mb-3" />

        <MudSelect T="string"
                   Label="Type"
                   @bind-Value="newQuestion.Type"
                   Required="true"
                   RequiredError="Type is required."
                   Immediate="true"
                   Class="mb-3">
            <MudSelectItem Value='@("dropdown")'>Dropdown</MudSelectItem>
            <MudSelectItem Value='@("text")'>Text</MudSelectItem>
            <MudSelectItem Value='@("yes_no")'>Yes/No</MudSelectItem>
            <MudSelectItem Value='@("number")'>Number</MudSelectItem>
            <MudSelectItem Value='@("multiselect")'>Multi-Select</MudSelectItem>
            <MudSelectItem Value='@("checkbox")'>Checkbox</MudSelectItem>
            <MudSelectItem Value='@("radio")'>Radio</MudSelectItem>
        </MudSelect>

        <MudSwitch T="bool"
                   Label="Required"
                   @bind-Value="newQuestion.Required"
                   Color="Color.Primary"
                   Class="mb-3" />

        <MudTextField T="string"
                      Label="Placeholder"
                      @bind-Value="newQuestion.Placeholder"
                      Immediate="true"
                      Class="mb-3" />

        <MudTextField T="string"
                      Label="Default Value"
                      @bind-Value="newQuestion.DefaultValue"
                      Immediate="true"
                      Class="mb-3" />

        <MudTextField T="string"
                      Label="Help Text"
                      @bind-Value="newQuestion.HelpText"
                      Immediate="true"
                      Lines="3"
                      Class="mb-4" />

        @if (IsOptionBasedType)
        {
            <MudText Typo="Typo.subtitle1" Class="mb-2">Options</MudText>

            @for (int i = 0; i < newQuestion.Options.Count; i++)
            {
                var index = i;
                <MudGrid Class="mb-2" data-option-row="@index">
                    <MudItem xs="5">
                        <MudTextField T="string"
                                      Label="Label"
                                      @bind-Value="newQuestion.Options[index].Label"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="5">
                        <MudTextField T="string"
                                      Label="Value"
                                      @bind-Value="newQuestion.Options[index].Value"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="2" Class="d-flex align-center">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="Remove option"
                                       OnClick="() => RemoveOption(index)" />
                    </MudItem>
                </MudGrid>
            }

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="AddOption"
                       Class="mb-4">
                Add Option
            </MudButton>
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(!CanCreate)"
                   OnClick="CreateQuestion">
            
            @if (_isSubmitting)
            {
                <MudProgressCircular 
                    Size="Size.Small" 
                    Indeterminate="true" 
                    Class="ml-2" />
                <span> Saving...</span>
            }else
            {
                <span>Create Question</span>
            }
            
        </MudButton>
    </MudForm>
</MudPaper>

@code {
    private MudForm? _form;
    private bool _isValid;

    bool _isSubmitting;

    private string? _errorMessage;
    private string? _successMessage;

    private NewQuestion newQuestion = new();

    private static readonly HashSet<string> OptionBasedTypes =
        new(StringComparer.OrdinalIgnoreCase) { "dropdown", "radio", "checkbox", "multiselect" };

    private bool IsOptionBasedType => OptionBasedTypes.Contains(newQuestion.Type);

    private bool CanCreate =>
        _isValid &&
        !string.IsNullOrWhiteSpace(newQuestion.Label) &&
        !string.IsNullOrWhiteSpace(newQuestion.Key) &&
        !string.IsNullOrWhiteSpace(newQuestion.Type);

    private void AddOption()
    {
        newQuestion.Options.Add(new Option { Label = string.Empty, Value = string.Empty });
    }

    private void RemoveOption(int index)
    {
        newQuestion.Options.RemoveAt(index);
    }

    private async Task CreateQuestion()
    {
        if (_form is null || !CanCreate)
            return;

        await _form.ValidateAsync();

        if (!_isValid)
            return;
        _isSubmitting = true;
        _successMessage = null;
        _errorMessage = null;

        var (success, error) = await QuestionService.CreateQuestionAsync(newQuestion);
        
        if(success)
        {
            _successMessage = $"Question '{newQuestion.Label}' created successfully.";
            newQuestion = new();
            await _form.ResetAsync();
        }
        else
        {
            _errorMessage = error ?? "An error occurred while creating the question.";
        }
        _isSubmitting = false;

    }
}
