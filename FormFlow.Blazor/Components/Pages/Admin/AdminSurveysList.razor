@page "/admin/surveys"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<MudPaper Class="pa-6" Elevation="2">

    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-4">

        <MudText Typo="Typo.h5" Class="mb-4">Survey Management</MudText>

        <MudButton Variant="Variant.Filled"
                Color="Color.Primary"
                Href="/admin/surveys/create">
            + Create Survey
        </MudButton>

    </MudStack>

    @if (surveys is null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (!surveys.Any())
    {
        <MudText>No surveys found.</MudText>
    }
    else
    {
        <MudTable Items="@surveys" 
                Hover="true" 
                Dense="true"
                Bordered="true"
                Elevation="3">
            <ToolBarContent>
                <MudText Typo="Typo.h6" Class="mb-2">Surveys</MudText>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Title</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Questions</MudTh>
                <MudTh></MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd>@context.Title</MudTd>
                <MudTd>@context.Description</MudTd>
                <MudTd>@context.QuestionIds.Count</MudTd>

                <MudTd>
                    <MudStack Row="true" Spacing="2" Class="mb-4" >

                        <MudButton Variant="Variant.Filled"
                                Color="Color.Primary"
                                OnClick="@(_ => { })">
                            Edit        
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                Color="Color.Primary"
                                OnClick="@(_ => PreviewSurvey(context.Id))">
                            Preview 
                        </MudButton>

                    </MudStack>
                </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager RowsPerPageString="10" />
            </PagerContent>
    
        </MudTable>
    }
</MudPaper>  

@code {
    private List<SurveyDefinition>? surveys;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("AdminApi");
        surveys = await client.GetFromJsonAsync<List<SurveyDefinition>>("api/surveys");
    }

    private async Task PreviewSurvey(Guid Id)
    {
        Nav.NavigateTo($"/admin/surveys/{Id}/preview");
    }
}
    
