@page "/admin/questions"
@using FormFlow.Blazor.Services
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Question Management</PageTitle>


<MudPaper Class="pa-4" Elevation="1">
    

    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-4">

        <MudText Typo="Typo.h5" Class="mb-2">Question Management</MudText>

        <MudButton Variant="Variant.Filled"
                    Color="Color.Primary"
                    Href="/admin/questions/create">
            Create New Question            
        </MudButton>
        
    </MudStack>

    @if (questions is null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> 
    }
    else if (!questions.Any())
    {
        <MudText>No questions found.</MudText>
    }
    else
    {
        <MudTable Items="@questions" 
                Hover="true" 
                Dense="true"
                Bordered="true"
                Elevation="3">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Question Bank</MudText>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Label</MudTh>
                <MudTh>Key</MudTh>
                <MudTh>Type</MudTh>
                <MudTh></MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd>@context.Label</MudTd>
                <MudTd>@context.Key</MudTd>
                <MudTd>@context.Type</MudTd>

                <MudTd>
                    <MudButton Variant="Variant.Filled"
                            Color="Color.Primary"
                            OnClick="@(_ => { })">
                        Edit        
                    </MudButton>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager RowsPerPageString="10" />
            </PagerContent>
        </MudTable>
    }

</MudPaper>

@code {
    private List<QuestionDefinition>? questions;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("AdminApi");
        questions = await client.GetFromJsonAsync<List<QuestionDefinition>>("api/questions");
    }

    private void EditQuestions(Guid id)
    {
        return;
        //Nav.NavigateTo($"/admin/questions/{id}/edit");
    }
}