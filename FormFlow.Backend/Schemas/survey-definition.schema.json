{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Survey Schema",
    "description": "Schema for defining a survey, which consists of multiple questions.",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique identifier for the survey.",
            "format": "uuid"
        },
        "title": {
            "type": "string",
            "description": "Title of the survey."
        },
        "description": {
            "type": "string",
            "description": "Description of the survey."
        },
        "questions": {
            "type": "array",
            "description": "List of question Ids included in the survey.",
            "items": {
                "type": "string",
                "format": "uuid"
            },
            "minItems": 1
            
        },
        "version": {
            "type": "integer",
            "description": "Version number of the survey definition."
        },
        "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the survey was created."
        }
    },
    "required": ["id", "title", "questions", "description","createdAt"]
}