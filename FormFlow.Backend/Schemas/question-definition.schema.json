{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Question Schema",
  "description": "Schema for defining questions in a form.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the question."
    },
    "key": {
      "type": "string",
      "description": "Key used to reference this question."
    },
    "label": {
      "type": "string",
      "description": "Label displayed for the question."
    },
    "type": {
      "type": "string",
      "enum": ["text", "number", "yes_no", "dropdown", "radio", "checkbox", "multiselect"],
      "description": "Type of input field (e.g., text, dropdown)."
    },
    "placeholder": {
      "type": "string",
      "description": "Placeholder text for the input field."
    },
    "defaultValue": {
      "description": "Default value for the question."
    },
    "visibleIf": {
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "shouldEqual": { "type": "boolean" }
      },
      "required": ["key", "equals"]
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "value": { "type": "string" },
          "label": { "type": "string" }
        },
        "required": ["value", "label"]
      }
    },
    "validationConfigs": {
      "description" : "Represents the internal structure of validation rules. NOTE: Although this schema defines validationConfigs as an array for documentation and tooling, the backend actually stores this value as a JSON-serialized string. Example backend format: \"[{\\\"validationType\\\":\\\"MinLength\\\",\\\"minLength\\\":1}]\". The QuestionValidationEngine deserializes this string at runtime.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "validationType": { "type": "string", "enum": ["MinValue", "MaxValue", "MinLength", "MaxLength", "Range"] },
          "minValue": { "type": "integer" },
          "maxValue": { "type": "integer" },

          "minLength": { "type": "integer"},
          "maxLength": { "type": "integer"},

          "message": { "type": "string"}
        },
        "required": ["validationType"]
      },
      "hints": [
        { "validationType": "MinLength", "minLength": 1 },
        { "validationType": "MaxLength", "maxLength": 100 },
        { "validationType": "MinValue", "minValue": 0 },
        { "validationType": "MaxValue", "maxValue": 120 },
        { "validationType": "Range", "minValue": 0, "maxValue": 10 }
      ]
    },
    "helpText": {
      "type": "string",
      "description": "Optional guidance for the user."
    }
  },
  "required": ["id", "key", "label", "type"],
  "if": {
    "properties": { "type": { "enum": ["dropdown", "radio", "checkbox", "multiselect"] } },
    "required": ["type"]
  },
  "then": {
    "required": ["options"]
  }
}