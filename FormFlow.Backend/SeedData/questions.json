    "type": "yes_no",
    "required": true
  },
  {
    "id": "c23f6a06-6a6b-4b45-8152-9d5bc38e0006",
    "key": "study_level",
    "label": "What is your highest level of study?",
    "type": "dropdown",
    "required": true,
    "options": [
      { "value": "high_school", "label": "High school" },
      { "value": "bachelor", "label": "Bachelor's degree" },
      { "value": "master", "label": "Master's degree" },
      { "value": "phd", "label": "PhD or higher" }
    ]
  },
  {
    "id": "d34a7b17-7b7c-4a65-9b12-4e6c49cf0007",
    "key": "contact_method",
    "label": "Preferred contact method",
    "type": "radio",
    "required": true,
    "options": [
      { "value": "email", "label": "Email" },
      { "value": "phone", "label": "Phone" },
      { "value": "text", "label": "Text message" }
    ]
  },
  {
    "id": "e45b8c28-8c8d-4d75-a4f3-5f7d1cfd0008",
    "key": "subscribe_newsletter",
    "label": "Subscribe to newsletter",
    "type": "checkbox",
    "required": false,
    "defaultValue": "false",
    "helpText": "Check this box if you want to receive updates and offers."
  },
  {
    "id": "f56c9d39-9d9e-4e85-b172-6f8e2dfe0009",
    "key": "skills",
    "label": "Which skills do you have?",
    "type": "multiselect",
    "required": true,
    "options": [
      { "value": "csharp", "label": "C#" },
      { "value": "javascript", "label": "JavaScript" },
      { "value": "sql", "label": "SQL" },
      { "value": "design", "label": "Design" },
      { "value": "management", "label": "Management" }
    ]
  },
  {
    "id": "a67d0e4a-0a0f-4f95-ba83-7f9e3c0f0010",
    "key": "campus_preference",
    "label": "Preferred campus location",
    "type": "dropdown",
    "required": true,
    "visibleIf": {
      "key": "is_student",
      "shouldEqual": true
    },
    "options": [
      { "value": "north", "label": "North campus" },
      { "value": "south", "label": "South campus" },
      { "value": "east", "label": "East campus" },
      { "value": "west", "label": "West campus" }
    ]
  }
]
