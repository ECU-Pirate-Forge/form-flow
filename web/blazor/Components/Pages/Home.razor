@page "/"
@using System.Text.Json
@using FormFlow.Blazor.Models
@inject HttpClient Http

<h3>Blazor Dynamic Question</h3>

@if (question != null)
{
    <QuestionRenderer Question="question" />
}

@code {
    private QuestionDefinition? question;

    protected override async Task OnInitializedAsync()
    {
        var json = await Http.GetStringAsync("sample-question.json");
        question = JsonSerializer.Deserialize<QuestionDefinition>(json);
    }
}